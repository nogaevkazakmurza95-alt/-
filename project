          font-family: 'Karla', sans-serif; font-size: 14px; padding: 8px 4px;
        }
        .pgc-nav-cta {
          border: 1.5px solid var(--pgc-ink) !important; border-radius: 3px; padding: 8px 16px !important;
        }
        .pgc-nav-cta:hover { background: var(--pgc-ink); color: var(--pgc-card); }

        .pgc-hero {
          display: grid; grid-template-columns: 1.3fr 0.8fr; align-items: center;
          padding: 56px 28px; gap: 32px; max-width: 1180px; margin: 0 auto;
        }
