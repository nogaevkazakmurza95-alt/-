          padding: 20px 28px; border-bottom: 1px solid var(--pgc-line);
          flex-wrap: wrap; gap: 12px;
        }
        .pgc-logo { display: flex; align-items: center; gap: 12px; }
        .pgc-logo-mark {
          width: 40px; height: 40px; border-radius: 50%;
          border: 2px solid var(--pgc-ink); display: flex; align-items: center; justify-content: center;
          font-family: 'Big Shoulders Stencil', sans-serif; font-weight: 700; font-size: 15px;
          transform: rotate(-6deg);
        }
        .pgc-logo-text { font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; line-height: 1.3; }
        .pgc-logo-text b { display: block; font-size: 15px; letter-spacing: 0.06em; }
        .pgc-nav { display: flex; align-items: center; gap: 20px; font-size: 14px; }
