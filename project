        @media (max-width: 760px) {
          .pgc-hero { grid-template-columns: 1fr; padding-top: 36px; }
          .pgc-ring-mark { max-width: 160px; }
          .pgc-panel-form { grid-template-columns: 1fr; }
        }
      `}</style>

      <header className="pgc-header">
        <div className="pgc-logo">
          <div className="pgc-logo-mark">ГК</div>
          <div className="pgc-logo-text">
            <b>Гипсовая мастерская</b>
            копилки ручной отливки
          </div>
        </div>
        <nav className="pgc-nav">
          <a href="#catalog">Каталог</a>
          {isAdmin ? (
            <button className="pgc-nav-cta" onClick={handleLogout}>Выйти</button>
          ) : (
            <button className="pgc-nav-cta" onClick={() => setShowLogin(true)}>Вход для мастера</button>
          )}
        </nav>
      </header>

      {isAdmin && (
        <div className="pgc-admin-bar">
          <span>Режим мастера — изменения видят все посетители сайта.</span>
          <div className="pgc-admin-bar-actions">
            <button onClick={() => setShowCredsForm(true)}>Сменить логин/пароль</button>
            <button onClick={handleLogout}>Выйти</button>
          </div>
        </div>
      )}

      <section className="pgc-hero">
        <div>
          <h1 className="pgc-display">Гипсовые копилки, отлитые вручную</h1>
          <p>
            Каждая форма отливается и расписывается вручную, поэтому у копилок нет двух
            одинаковых. Смотрите каталог — фото и цены мастер обновляет сам, прямо с этой страницы.
          </p>
        </div>
        <RingMark />
      </section>

      <div className="pgc-section-label" id="catalog">
        <span>Каталог</span>
        <div className="line" />
      </div>

      {loading ? (
        <div className="pgc-empty">Загружаем каталог…</div>
      ) : items.length === 0 ? (
        <div className="pgc-empty">
          {isAdmin
            ? "Пока в каталоге пусто. Добавьте первую копилку через форму ниже."
            : "Мастер скоро добавит фотографии копилок — загляните позже."}
        </div>
      ) : (
        <div className="pgc-grid">
          {items.map((item) => (
            <div className="pgc-card" key={item.id}>
              <StampBadge number={item.moldNumber} />
              <img className="pgc-card-photo" src={item.image} alt={item.name} />
              <div className="pgc-card-body">
                <h3>{item.name}</h3>
                {item.price && <div className="pgc-price">{item.price}</div>}
                {item.description && <p>{item.description}</p>}
                {isAdmin && (
                  <div className="pgc-card-admin-row">
                    <button className="pgc-mini-btn" onClick={() => startEdit(item)}>Изменить</button>
                    <button className="pgc-mini-btn danger" onClick={() => handleDelete(item.id)}>Удалить</button>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      )}

      {isAdmin && (
        <div className="pgc-panel">
          <div className="pgc-section-label">
            <span>Панель мастера</span>
            <div className="line" />
          </div>
          <form className="pgc-panel-form" onSubmit={handleSubmit}>
            <h2>{editingId ? "Изменить копилку" : "Добавить новую копилку"}</h2>

            <div className="pgc-field">
              <label>Название</label>
              <input
                value={form.name}
                onChange={(e) => setForm((f) => ({ ...f, name: e.target.value }))}
                placeholder="Например, «Кот-копилка»"
              />
            </div>
            <div className="pgc-field">
              <label>Цена</label>
              <input
                value={form.price}
                onChange={(e) => setForm((f) => ({ ...f, price: e.target.value }))}
                placeholder="Например, 1200 ₽"
              />
            </div>
            <div className="pgc-field pgc-full">
              <label>Описание</label>
              <textarea
                value={form.description}
                onChange={(e) => setForm((f) => ({ ...f, description: e.target.value }))}
                placeholder="Размер, цвет, особенности росписи…"
              />
            </div>
            <div className="pgc-field pgc-full">
              <label>Фото</label>
              <input type="file" accept="image/*" ref={fileInputRef} onChange={handleFileChange} />
              {form.image && <img src={form.image} alt="Предпросмотр" className="pgc-file-preview" />}
            </div>

            <div className="pgc-form-actions">
              <button className="pgc-btn" type="submit" disabled={saving} style={{ width: "auto" }}>
                {saving ? "Сохраняем…" : editingId ? "Сохранить изменения" : "Добавить в каталог"}
              </button>
              {editingId && (
                <button type="button" className="pgc-mini-btn" onClick={resetForm}>Отменить</button>
              )}
            </div>
          </form>
        </div>
      )}

      {storageError && (
        <div className="pgc-empty" style={{ maxWidth: 1124, margin: "0 auto 40px" }}>
          Не удалось сохранить изменения. Попробуйте ещё раз через минуту.
        </div>
      )}

      <footer className="pgc-footer">
        Гипсовая мастерская · сделано вручную · {isAdmin ? "вы вошли как мастер" : (
          <button onClick={() => setShowLogin(true)}>вход для мастера</button>
        )}
      </footer>

      {showLogin && (
        <div className="pgc-overlay" onClick={() => setShowLogin(false)}>
          <div className="pgc-modal" onClick={(e) => e.stopPropagation()}>
            <h2 className="pgc-display">Вход мастера</h2>
            <p className="pgc-sub">Логин и пароль от панели управления каталогом.</p>
            <form onSubmit={handleLogin}>
              <div className="pgc-field">
                <label>Логин</label>
                <input
                  value={loginForm.login}
                  onChange={(e) => setLoginForm((f) => ({ ...f, login: e.target.value }))}
                  autoFocus
                />
              </div>
              <div className="pgc-field">
                <label>Пароль</label>
                <input
                  type="password"
                  value={loginForm.password}
                  onChange={(e) => setLoginForm((f) => ({ ...f, password: e.target.value }))}
                />
              </div>
              {loginError && <div className="pgc-error">{loginError}</div>}
              <button className="pgc-btn" type="submit">Войти</button>
            </form>
            <button className="pgc-link-btn" onClick={() => setShowLogin(false)}>Закрыть</button>
          </div>
        </div>
      )}

      {showCredsForm && (
        <div className="pgc-overlay" onClick={() => setShowCredsForm(false)}>
          <div className="pgc-modal" onClick={(e) => e.stopPropagation()}>
            <h2 className="pgc-display">Новый логин и пароль</h2>
            <p className="pgc-sub">Текущий логин: {credentials.login}</p>
            <form onSubmit={handleCredsSubmit}>
              <div className="pgc-field">
                <label>Новый логин</label>
                <input
                  value={credsForm.login}
                  onChange={(e) => setCredsForm((f) => ({ ...f, login: e.target.value }))}
                  autoFocus
                />
              </div>
              <div className="pgc-field">
                <label>Новый пароль</label>
                <input
                  type="password"
                  value={credsForm.password}
                  onChange={(e) => setCredsForm((f) => ({ ...f, password: e.target.value }))}
                />
              </div>
              <button className="pgc-btn" type="submit">Сохранить</button>
            </form>
            <button className="pgc-link-btn" onClick={() => setShowCredsForm(false)}>Закрыть</button>
          </div>
        </div>
      )}
    </div>
  );
}
