import { useState, useEffect, useRef } from "react";

/*
  Гипсовая мастерская — каталог + панель мастера.

  Данные хранятся в персистентном хранилище артефакта:
  - "catalog-items" (shared: true)  — список копилок, виден всем посетителям
  - "admin-credentials" (shared: true) — логин/пароль мастера (можно сменить в панели)

  ВАЖНО: это клиентская проверка пароля внутри артефакта, а не настоящая
  серверная авторизация. Она отлично подходит, чтобы отделить "витрину"
  от "мастерской" на этом прототипе, но не защищает от человека, который
  умеет читать код страницы. Для реального сайта с надёжной защитой
  понадобится бэкенд.
*/

const DEFAULT_CREDENTIALS = { login: "master", password: "gips2026" };

function readFileAsDataURL(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = () => reject(reader.error);
    reader.readAsDataURL(file);
  });
}

function StampBadge({ number }) {
  return (
    <div className="pgc-stamp" aria-hidden="true">
      <span>ФОРМА</span>
      <strong>№{String(number).padStart(3, "0")}</strong>
    </div>
  );
}

function RingMark() {
  return (
    <svg viewBox="0 0 240 240" className="pgc-ring-mark" aria-hidden="true">
      <circle cx="120" cy="120" r="112" fill="none" stroke="var(--pgc-clay)" strokeWidth="1.5" opacity="0.35" />
      <circle cx="120" cy="120" r="86" fill="none" stroke="var(--pgc-ink)" strokeWidth="1.5" opacity="0.5" />
      <circle cx="120" cy="120" r="60" fill="none" stroke="var(--pgc-clay)" strokeWidth="2" opacity="0.7" />
      <circle cx="120" cy="120" r="34" fill="var(--pgc-clay)" opacity="0.9" />
      <circle cx="120" cy="120" r="34" fill="none" stroke="var(--pgc-ink)" strokeWidth="1" opacity="0.4" />
    </svg>
  );
}

export default function App() {
  const [items, setItems] = useState([]);
  const [credentials, setCredentials] = useState(DEFAULT_CREDENTIALS);
  const [loading, setLoading] = useState(true);
  const [storageError, setStorageError] = useState(false);

  const [isAdmin, setIsAdmin] = useState(false);
  const [showLogin, setShowLogin] = useState(false);
  const [loginForm, setLoginForm] = useState({ login: "", password: "" });
  const [loginError, setLoginError] = useState("");

  const [form, setForm] = useState({ name: "", price: "", description: "", image: "" });
  const [editingId, setEditingId] = useState(null);
  const [saving, setSaving] = useState(false);
  const [showCredsForm, setShowCredsForm] = useState(false);
  const [credsForm, setCredsForm] = useState({ login: "", password: "" });

  const fileInputRef = useRef(null);

  useEffect(() => {
    async function load() {
      try {
        const itemsRes = await window.storage.get("catalog-items", true);
        setItems(itemsRes ? JSON.parse(itemsRes.value) : []);
      } catch (e) {
        setItems([]);
      }
      try {
        const credsRes = await window.storage.get("admin-credentials", true);
        setCredentials(credsRes ? JSON.parse(credsRes.value) : DEFAULT_CREDENTIALS);
      } catch (e) {
        setCredentials(DEFAULT_CREDENTIALS);
      }
      setLoading(false);
    }
    load();
  }, []);

  async function persistItems(next) {
    setItems(next);
    try {
      const res = await window.storage.set("catalog-items", JSON.stringify(next), true);
      if (!res) setStorageError(true);
    } catch (e) {
      setStorageError(true);
    }
  }

  function handleLogin(e) {
    e.preventDefault();
    if (loginForm.login === credentials.login && loginForm.password === credentials.password) {
      setIsAdmin(true);
      setShowLogin(false);
      setLoginForm({ login: "", password: "" });
      setLoginError("");
    } else {
      setLoginError("Неверный логин или пароль.");
    }
  }

  function handleLogout() {
    setIsAdmin(false);
    setEditingId(null);
    setForm({ name: "", price: "", description: "", image: "" });
  }

  async function handleFileChange(e) {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 4 * 1024 * 1024) {
      alert("Файл слишком большой. Пожалуйста, выберите фото до 4 МБ.");
      return;
    }
    const dataUrl = await readFileAsDataURL(file);
    setForm((f) => ({ ...f, image: dataUrl }));
  }

  function startEdit(item) {
    setEditingId(item.id);
    setForm({ name: item.name, price: item.price, description: item.description, image: item.image });
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function resetForm() {
    setEditingId(null);
    setForm({ name: "", price: "", description: "", image: "" });
    if (fileInputRef.current) fileInputRef.current.value = "";
  }

  async function handleSubmit(e) {
    e.preventDefault();
    if (!form.name.trim() || !form.image) {
      alert("Укажите название и загрузите фото копилки.");
      return;
    }
    setSaving(true);
    let next;
    if (editingId) {
      next = items.map((it) => (it.id === editingId ? { ...it, ...form } : it));
    } else {
      const nextNumber =
        items.length > 0 ? Math.max(...items.map((it) => it.moldNumber || 0)) + 1 : 1;
      next = [...items, { id: Date.now().toString(), moldNumber: nextNumber, ...form }];
    }
    await persistItems(next);
    setSaving(false);
    resetForm();
  }

  async function handleDelete(id) {
    if (!confirm("Удалить эту копилку из каталога?")) return;
    await persistItems(items.filter((it) => it.id !== id));
    if (editingId === id) resetForm();
  }

  async function handleCredsSubmit(e) {
    e.preventDefault();
    if (!credsForm.login.trim() || !credsForm.password.trim()) return;
    const next = { login: credsForm.login.trim(), password: credsForm.password };
    setCredentials(next);
    try {
      await window.storage.set("admin-credentials", JSON.stringify(next), true);
    } catch (e) {}
    setShowCredsForm(false);
    setCredsForm({ login: "", password: "" });
  }

  return (
    <div className="pgc-root">
